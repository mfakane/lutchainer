{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types/browser",
    "lib": ["ES2020", "DOM"],
    "types": []
  },
  "include": [
    "src/app/browser/**/*.ts",
    "src/app/browser/**/*.svelte",
    "src/platforms/browser/**/*.ts",
    "src/platforms/webgl/**/*.ts",
    "src/shared/**/*.ts",
    "src/features/**/*.ts",
  ]
}
