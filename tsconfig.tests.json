{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types/tests",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.mts",
    "tests/**/*.d.ts",
    "src/app/browser/pipeline/pipeline-apply.ts",
    "src/app/cli/**/*.ts",
    "src/features/**/*.ts",
    "src/platforms/webgl/renderer.ts",
    "src/platforms/webgl/lut-texture-utils.ts",
    "src/platforms/node/**/*.ts",
    "src/shared/**/*.ts",
    "src/types/node-shim.d.ts"
  ]
}
