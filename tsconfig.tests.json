{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types/tests",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.mts",
    "tests/**/*.d.ts",
    "src/features/**/*.ts",
    "src/shared/**/*.ts",
    "src/types/node-shim.d.ts"
  ],
  "exclude": [
    "src/app/**",
    "src/platforms/**"
  ]
}
