{
  "name": "lutchainer",
  "version": "1.0.0",
  "description": "Browser-based LUT chaining shader editor with WebGL preview",
  "license": "CC0-1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lutchainer": "./dist/cli/main.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "serve": "node dist/cli/main.mjs serve",
    "test": "npm run build && node --test tests/cli/*.test.mts tests/features/*.test.mts tests/shared/*.test.mts tests/shader/*.test.mts",
    "test:step": "npm run build && node --test tests/features/step*.test.mts",
    "test:pipeline": "npm run build && node --test tests/features/pipeline*.test.mts",
    "test:shared": "npm run build && node --test tests/shared/*.test.mts",
    "test:shader": "npm run build && node --test tests/shader/shader-generator.test.mts",
    "test:shader:strict": "npm run build && node --test tests/shader/strict-compilers.test.mts",
    "test:ui": "playwright test",
    "test:ui:smoke": "playwright test tests/ui/main-ui-smoke.spec.ts",
    "test:ui:sensitive": "playwright test tests/ui/list-scroll-and-connection-redraw.spec.ts",
    "test:ui:headed": "playwright test --headed",
    "test:ui:install": "playwright install --with-deps chromium",
    "test:watch": "node --watch --test tests/**/*.test.mts",
    "validate:lutchain-examples": "node tests/lutchain/validate-examples.mts",
    "typecheck": "tsc --build tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.0",
    "esbuild": "^0.20.0",
    "gl": "^8.1.6",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "svelte": "^5.55.4"
  }
}
