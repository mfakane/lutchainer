{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types/cli",
    "lib": ["ES2020"],
    "types": ["node"]
  },
  "include": [
    "src/app/cli/**/*.ts",
    "src/platforms/node/**/*.ts",
    "src/shared/**/*.ts",
    "src/features/**/*.ts",
    "src/types/node-shim.d.ts"
  ]
}
