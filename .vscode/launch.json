{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "editor-browser",
      "request": "launch",
      "name": "Browser",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/dist/web"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Server",
      "command": "npm run serve",
      "localRoot": "${workspaceFolder}/dist/cli",
    }
  ],
  "compounds": [
    {
      "name": "Browser/Server",
      "configurations": ["Browser", "Server"],
      "preLaunchTask": "npm: build",
      "stopAll": true,
    }
  ]
}