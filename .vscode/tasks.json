{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: Type Check and Build",
      "type": "shell",
      "command": "npx tsc --noEmit && npm run build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}