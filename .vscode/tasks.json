{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: Type Check and Build",
      "type": "shell",
      "command": "npx tsc --noEmit && npm run build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": true,
        "revealProblems": "onProblem"
      }
    },
    {
      "label": "TypeScript: Type Check",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": true,
        "revealProblems": "onProblem"
      }
    }
  ]
}